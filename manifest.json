{
  "manifest_version": 3,
  "name": "Babelfish Exporter",
  "version": "0.1.0",
  "description": "Export AI chat conversations (ChatGPT, Claude, Gemini, Copilot) to clean Markdown files.",

  "permissions": ["activeTab"],

  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://copilot.microsoft.com/*",
    "*://gemini.google.com/*",
    "*://aistudio.google.com/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Export chat to Markdown"
  },

  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://copilot.microsoft.com/*",
        "*://gemini.google.com/*",
        "*://aistudio.google.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
