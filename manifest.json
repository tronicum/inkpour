{
  "manifest_version": 3,
  "name": "Inkpour",
  "version": "0.1.0",
  "description": "Export AI chat conversations (ChatGPT, Claude, Gemini, Copilot, and more) to Markdown, PDF, HTML or JSON.",

  "permissions": ["activeTab", "tabs", "storage", "downloads", "clipboardWrite", "contextMenus"],

  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://copilot.microsoft.com/*",
    "*://www.copilot.com/*",
    "*://copilot.com/*",
    "*://gemini.google.com/*",
    "*://aistudio.google.com/*",
    "*://grok.com/*",
    "*://perplexity.ai/*",
    "*://chat.deepseek.com/*",
    "*://meta.ai/*",
    "*://chat.mistral.ai/*",
    "*://huggingface.co/chat*",
    "*://poe.com/*",
    "*://www.phind.com/*",
    "*://notebooklm.google.com/*",
    "*://kagi.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "commands": {
    "export-markdown": {
      "suggested_key": { "default": "Alt+Shift+M", "mac": "Alt+Shift+M" },
      "description": "Export current chat to Markdown"
    },
    "copy-markdown": {
      "suggested_key": { "default": "Alt+Shift+C", "mac": "Alt+Shift+C" },
      "description": "Copy current chat as Markdown to clipboard"
    },
    "copy-html": {
      "suggested_key": { "default": "Alt+Shift+H", "mac": "Alt+Shift+H" },
      "description": "Copy current chat as standalone HTML to clipboard"
    },
    "export-pdf": {
      "suggested_key": { "default": "Alt+Shift+P", "mac": "Alt+Shift+P" },
      "description": "Export current chat to PDF"
    },
    "export-json": {
      "suggested_key": { "default": "Alt+Shift+J", "mac": "Alt+Shift+J" },
      "description": "Export current chat to JSON"
    },
    "export-zip": {
      "suggested_key": { "default": "Alt+Shift+Z", "mac": "Alt+Shift+Z" },
      "description": "Export current chat as ZIP (chat.md + code files)"
    }
  },

  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Inkpour",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://copilot.microsoft.com/*",
        "*://www.copilot.com/*",
        "*://copilot.com/*",
        "*://gemini.google.com/*",
        "*://aistudio.google.com/*",
        "*://grok.com/*",
        "*://perplexity.ai/*",
        "*://chat.deepseek.com/*",
        "*://meta.ai/*",
        "*://chat.mistral.ai/*",
        "*://huggingface.co/chat*",
        "*://poe.com/*",
        "*://www.phind.com/*",
        "*://notebooklm.google.com/*",
        "*://kagi.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["print.html", "history.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
