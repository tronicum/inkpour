{
  "manifest_version": 3,
  "name": "Inkpour",
  "version": "0.4.23.1",
  "description": "Export AI chat conversations (ChatGPT, Claude, Gemini, Copilot, and more) to Markdown, PDF, HTML, DOCX or ZIP.",
  "homepage_url": "https://github.com/tronicum/inkpour",
  "author": "tronicum",

  "browser_specific_settings": {
    "gecko": {
      "id": "inkpour@tronicum",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  },

  "permissions": ["activeTab", "tabs", "storage", "downloads", "clipboardWrite", "contextMenus"],

  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://copilot.microsoft.com/*",
    "*://www.copilot.com/*",
    "*://copilot.com/*",
    "*://gemini.google.com/*",
    "*://aistudio.google.com/*",
    "*://www.google.com/search*",
    "*://google.com/search*",
    "*://grok.com/*",
    "*://console.groq.com/*",
    "*://perplexity.ai/*",
    "*://chat.deepseek.com/*",
    "*://meta.ai/*",
    "*://chat.mistral.ai/*",
    "*://huggingface.co/chat*",
    "*://poe.com/*",
    "*://www.phind.com/*",
    "*://notebooklm.google.com/*",
    "*://kagi.com/*",
    "*://chat.z.ai/*",
    "*://venice.ai/*",
    "*://lmarena.ai/*",
    "*://chat.lmsys.org/*",
    "*://character.ai/*",
    "*://www.character.ai/*",
    "*://coral.cohere.com/*",
    "*://pi.ai/*",
    "*://api.github.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "commands": {
    "export-markdown": {
      "suggested_key": { "default": "Alt+Shift+M", "mac": "Alt+Shift+M" },
      "description": "Export current chat to Markdown"
    },
    "copy-markdown": {
      "suggested_key": { "default": "Alt+Shift+C", "mac": "Alt+Shift+C" },
      "description": "Copy current chat as Markdown to clipboard"
    },
    "export-pdf": {
      "suggested_key": { "default": "Alt+Shift+P", "mac": "Alt+Shift+P" },
      "description": "Export current chat to PDF"
    },
    "upload-gist": {
      "suggested_key": { "default": "Alt+Shift+G", "mac": "Alt+Shift+G" },
      "description": "Upload current chat to GitHub Gist"
    },
    "copy-html": {
      "description": "Copy current chat as standalone HTML to clipboard"
    },
    "export-json": {
      "description": "Export current chat to JSON"
    },
    "export-zip": {
      "description": "Export current chat as ZIP (chat.md + code files)"
    },
    "export-docx": {
      "suggested_key": { "default": "Alt+Shift+D", "mac": "Alt+Shift+D" },
      "description": "Export current chat to Word document (.docx)"
    }
  },

  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Inkpour",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://copilot.microsoft.com/*",
        "*://www.copilot.com/*",
        "*://copilot.com/*",
        "*://gemini.google.com/*",
        "*://aistudio.google.com/*",
        "*://www.google.com/search*",
        "*://google.com/search*",
        "*://grok.com/*",
        "*://console.groq.com/*",
        "*://perplexity.ai/*",
        "*://chat.deepseek.com/*",
        "*://meta.ai/*",
        "*://chat.mistral.ai/*",
        "*://huggingface.co/chat*",
        "*://poe.com/*",
        "*://www.phind.com/*",
        "*://notebooklm.google.com/*",
        "*://kagi.com/*",
        "*://chat.z.ai/*",
        "*://venice.ai/*",
        "*://lmarena.ai/*",
        "*://chat.lmsys.org/*",
        "*://character.ai/*",
        "*://www.character.ai/*",
        "*://coral.cohere.com/*",
        "*://pi.ai/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["print.html", "history.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
