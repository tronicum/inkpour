{
  "manifest_version": 3,
  "name": "Inkpour",
  "version": "0.1.0",
  "description": "Export AI chat conversations (ChatGPT, Claude, Gemini, Copilot) to Markdown, PDF and more.",

  "permissions": ["activeTab", "tabs", "storage"],

  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://copilot.microsoft.com/*",
    "*://gemini.google.com/*",
    "*://aistudio.google.com/*"
  ],

  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Inkpour",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://copilot.microsoft.com/*",
        "*://gemini.google.com/*",
        "*://aistudio.google.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["print.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
